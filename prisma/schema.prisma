// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  password      String?
  provider      String
  providerId    String?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())

  wishlistItems WishlistItem[]
  tasks         Task[]
  habits        Habit[]
  wallets       Wallet[]
  categories    Category[]
  transactions  Transaction[]
  slips         PaymentSlip[]
  investments   InvestmentAsset[]
  subscriptions Subscription[]
  goals         YearlyGoal[]
  settings      UserSettings?
}

model WishlistItem {
  id                String           @id @default(cuid())
  name              String
  price             Decimal
  priority          WishlistPriority @default(MEDIUM)
  status            WishlistStatus   @default(ACTIVE)
  url               String?
  image             String?
  lastTransactionId String?
  note              String?
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())
}

enum WishlistPriority {
  LOW
  MEDIUM
  HIGH
}

enum WishlistStatus {
  ACTIVE
  BOUGHT
}

model Task {
  id        String       @id @default(cuid())
  title     String
  completed Boolean      @default(false)
  date      String       // ISO Date "YYYY-MM-DD"
  priority  TaskPriority @default(MEDIUM)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Habit {
  id             String   @id @default(cuid())
  name           String
  streak         Int      @default(0)
  completedDates String[] // Array of "YYYY-MM-DD"
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id           String     @id @default(cuid())
  name         String
  type         WalletType
  balance      Decimal    @default(0)
  color        String?
  icon         String?
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[] @relation("WalletTransactions")
  transfers    Transaction[] @relation("TargetWalletTransactions")
}

enum WalletType {
  CASH
  BANK
  CREDIT
  INVESTMENT
  OTHER
}

model Category {
  id           String          @id @default(cuid())
  name         String
  type         TransactionType
  icon         String?
  color        String?
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

enum TransactionType {
  income
  expense
  transfer
  adjustment
}

model Transaction {
  id             String          @id @default(cuid())
  date           DateTime        @default(now())
  amount         Decimal
  type           TransactionType
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id])
  walletId       String
  wallet         Wallet          @relation("WalletTransactions", fields: [walletId], references: [id])
  targetWalletId String?
  targetWallet   Wallet?         @relation("TargetWalletTransactions", fields: [targetWalletId], references: [id])
  note           String?
  slipId         String?
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentSlip {
  id                  String   @id @default(cuid())
  fileName            String
  uploadDate          DateTime @default(now())
  imagePath           String
  qrData              Json?    // Store qrData as JSON (amount, recipient, etc.)
  linkedTransactionId String?
  note                String?
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvestmentAsset {
  id             String         @id @default(cuid())
  name           String
  type           InvestmentType
  amountInvested Decimal
  currentValue   Decimal
  note           String?
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt      DateTime       @updatedAt
}

enum InvestmentType {
  STOCK
  CRYPTO
  FUND
  OTHER
}

model Subscription {
  id                String       @id @default(cuid())
  name              String
  price             Decimal
  cycle             BillingCycle
  nextBillingDate   DateTime?
  lastPaidDate      DateTime?
  lastTransactionId String?
  url               String?
  note              String?
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BillingCycle {
  DAILY
  MONTHLY
  YEARLY
}

model YearlyGoal {
  id          String     @id @default(cuid())
  title       String
  year        Int
  status      GoalStatus @default(NOT_STARTED)
  description String?
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
}

model UserSettings {
  userId          String  @id
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme           Theme   @default(SYSTEM)
  currency        String  @default("THB")
  defaultWalletId String?
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}
